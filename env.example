# ============================================================
# .env.example — copy to .env and fill in real values
# DO NOT commit your real .env file to GitHub.
# ============================================================

# ── SQL Server (Ali's on-prem Silver source) ──
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=master
MSSQL_USER=sa
MSSQL_PASSWORD=Your_password123
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# ── Local output paths ──
PARQUET_DIR=./data/parquet
LOG_DIR=./logs

# ── BigQuery (Amr's target — Phase 3 handoff) ──
GCP_PROJECT_ID=fmcg-data-warehouse
GCS_BUCKET=fmcg-elshabasy-silver
BIGQUERY_DATASET=fmcg_silver
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
